APP_NAME=DarLysAPI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.darlys.site

FRONTEND_URL=https://darlys.site

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=darlys
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_DOMAIN=.darlys.site
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=darlys.site,www.darlys.site,localhost:5173

STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

ADMIN_BOOTSTRAP_SECRET=change-me-to-a-long-random-string
